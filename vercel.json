{
  "buildCommand": "npm install",
  "outputDirectory": "src",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing.html"
    }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    }
  ]
}